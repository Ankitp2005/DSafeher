PORT=3000
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_number
REDIS_URL=redis://localhost:6379
RATE_LIMIT_ENABLED=true
ADMIN_BYPASS_LIST=admin_user_id_1,admin_user_id_2
# Auth Secrets (Min 64 characters recommended for HS256)
JWT_ACCESS_SECRET=your_super_long_access_token_secret_at_least_64_chars
JWT_REFRESH_SECRET=your_super_long_refresh_token_secret_at_least_64_chars

# Database (Prisma)
DATABASE_URL=postgresql://user:password@host:5432/safeher?schema=public

# Encryption (32-byte hex = 64 characters)
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here_generate_with_openssl
